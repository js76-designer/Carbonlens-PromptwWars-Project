# Copy this file to .env (or set these in your hosting provider's
# dashboard, e.g. Render → Environment) and fill in real values.
# Never commit a real .env file to version control.

# Set to "production" when deployed (enables secure cookies, HSTS, etc.)
NODE_ENV=production

# A long, random, unique string used to sign session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-this-with-a-long-random-string

# The exact origin your app is deployed at (used for the CORS allow-list).
# Example: https://carbonlens.onrender.com
APP_ORIGIN=https://your-app.onrender.com

# Optional — override where the JSON data file is stored.
# DB_PATH=/absolute/path/to/carbonlens-data.json
